# ------------------------------------------------------------------
# Subdiu — Ortam Değişkenleri (Environment Variables)
#
# Kurulum:  cp .env.example .env.local   (sonra aşağıdaki değerleri doldur)
# Değerler: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------

# Supabase proje URL'in — örn. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase "anon / public" anahtarı (public anahtar — erişimi RLS korur)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Uygulamanın temel URL'i (OAuth redirect için). Lokalde:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
